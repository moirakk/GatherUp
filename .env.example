NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Keep service role keys server-only. Never expose them with NEXT_PUBLIC_.
# Required only for opt-in clean dev/staging RPC integration tests and server-only admin checks.
# SUPABASE_SERVICE_ROLE_KEY=

# Opt-in only. Keep disabled unless the target is a disposable clean dev/staging Supabase project.
# GATHERUP_RUN_RPC_INTEGRATION=1
# GATHERUP_RPC_INTEGRATION_TARGET=clean-dev
# GATHERUP_RPC_INTEGRATION_ALLOWED_REF=<clean-dev-project-ref>

# Explicit demo mode: serve mock data even when Supabase is configured.
# Never enable in production. Without this flag, configured deployments surface
# query failures as empty states instead of silently showing mock data.
# NEXT_PUBLIC_GATHERUP_DEMO_MODE=1

# Server-only opt-in to keep prototype (local, non-Supabase) auth reachable in
# production. Prototype auth is enabled automatically outside production;
# leave this unset in production unless you intentionally want to demo the
# app without a configured Supabase project.
# DEMO_MODE=true

# Supabase project ref used by `npm run db:types` / Supabase CLI workflows.
# GATHERUP_SUPABASE_PROJECT_REF=

# Required to authenticate Vercel Cron requests to /api/jobs/run (seat lock
# and waitlist invitation expiry cleanup). Vercel automatically sends this
# value as `Authorization: Bearer <CRON_SECRET>` when invoking the cron job.
# CRON_SECRET=

# Resend email delivery. RESEND_API_KEY is the Resend API key used to send
# notification emails; RESEND_FROM_EMAIL is the verified sender address.
# Required for the email notification_deliveries channel to send.
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=notifications@example.com

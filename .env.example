NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Keep service role keys server-only. Never expose them with NEXT_PUBLIC_.
# Required only for opt-in clean dev/staging RPC integration tests and server-only admin checks.
# SUPABASE_SERVICE_ROLE_KEY=

# Opt-in only. Keep disabled unless the target is a disposable clean dev/staging Supabase project.
# GATHERUP_RUN_RPC_INTEGRATION=1
# GATHERUP_RPC_INTEGRATION_TARGET=clean-dev
# GATHERUP_RPC_INTEGRATION_ALLOWED_REF=<clean-dev-project-ref>

# Explicit demo mode: serve mock data even when Supabase is configured.
# Never enable in production. Without this flag, configured deployments surface
# query failures as empty states instead of silently showing mock data.
# NEXT_PUBLIC_GATHERUP_DEMO_MODE=1

# Supabase project ref used by `npm run db:types` / Supabase CLI workflows.
# GATHERUP_SUPABASE_PROJECT_REF=

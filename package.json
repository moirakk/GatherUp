{
  "name": "gatherup",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "dev:webpack": "next dev --webpack",
    "build": "next build",
    "test": "node --test tests/*.test.mts",
    "test:auth": "node --test tests/auth-rules.test.mts",
    "test:integration:rpc": "node --test tests/integration/rpc/*.test.mts",
    "test:schema": "node --test tests/schema-contract.test.mts",
    "verify": "npm test && npm run typecheck",
    "start": "next start",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/ssr": "0.12.0",
    "@supabase/supabase-js": "2.108.1",
    "exceljs": "4.4.0",
    "lucide-react": "1.16.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@types/node": "25.8.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "typescript": "6.0.3"
  }
}
